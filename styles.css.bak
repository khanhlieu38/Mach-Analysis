/* MẠCH report styles — cards, badges, quotes */

:root {
  --ink: #2C3E50;
  --muted: #7F8C8D;
  --line: #ECF0F1;
  --accent: #D4A574;
  --bg-soft: #FBF7F2;
}

body { color: var(--ink); }
h1, h2, h3 { color: var(--ink); }
h2 { border-bottom: 2px solid var(--accent); padding-bottom: 0.4rem; margin-top: 2.5rem; }

/* ───────── KPI tiles ───────── */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin: 1.5rem 0 2rem;
}
.kpi {
  background: linear-gradient(135deg, #FBF7F2 0%, #F4E8D6 100%);
  border-left: 4px solid var(--accent);
  border-radius: 8px;
  padding: 1.1rem 1rem;
}
.kpi-value { font-size: 2rem; font-weight: 700; color: var(--ink); line-height: 1; }
.kpi-label { font-size: 0.85rem; color: var(--muted); margin-top: 0.4rem; font-weight: 600; }
.kpi-sub { font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; font-style: italic; }

/* ───────── Finding badges ───────── */
.findings-list { margin: 1.2rem 0 2rem; }
.finding {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  padding: 0.7rem 1rem;
  border-bottom: 1px solid var(--line);
}
.finding:last-child { border-bottom: none; }
.badge {
  display: inline-block;
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.25rem 0.6rem;
  border-radius: 12px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  white-space: nowrap;
  min-width: 90px;
  text-align: center;
}
.finding-text { font-size: 0.95rem; }

/* ───────── Profile cards ───────── */
.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin: 1.5rem 0;
}
.profile {
  background: white;
  border: 1px solid var(--line);
  border-top: 3px solid var(--accent);
  border-radius: 6px;
  padding: 1rem 1.1rem;
}
.profile-id {
  font-weight: 700;
  font-size: 1.05rem;
  color: var(--accent);
  margin-bottom: 0.6rem;
  letter-spacing: 0.05em;
}
.profile-row {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.3rem 0;
  font-size: 0.85rem;
  border-top: 1px dashed var(--line);
}
.profile-row span { color: var(--muted); }
.profile-row b { text-align: right; color: var(--ink); font-weight: 500; }

/* ───────── Quote cards ───────── */
.quote-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin: 1.2rem 0 2rem;
}
.quote-card {
  background: var(--bg-soft);
  border-left: 3px solid var(--accent);
  border-radius: 4px;
  padding: 1rem 1.2rem;
  position: relative;
}
.quote-attr {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 0.08em;
  margin-bottom: 0.4rem;
}
.quote-title {
  font-size: 0.8rem;
  color: var(--muted);
  font-style: italic;
  margin-bottom: 0.4rem;
}
.quote-text {
  font-size: 0.95rem;
  line-height: 1.5;
  color: var(--ink);
}

/* ───────── Recommendation rows ───────── */
.rec-list { margin: 1.2rem 0 2rem; }
.rec-row {
  display: grid;
  grid-template-columns: 40px 1fr 180px;
  gap: 1rem;
  align-items: center;
  padding: 1rem;
  border: 1px solid var(--line);
  border-radius: 6px;
  margin-bottom: 0.6rem;
  background: white;
}
.rec-num {
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--accent);
  text-align: center;
  line-height: 1;
}
.rec-change { font-size: 0.95rem; font-weight: 600; color: var(--ink); }
.rec-evidence { font-size: 0.8rem; color: var(--muted); margin-top: 0.25rem; }
.rec-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.4rem;
}
.owner {
  display: inline-block;
  background: var(--line);
  color: var(--ink);
  font-size: 0.75rem;
  padding: 0.2rem 0.6rem;
  border-radius: 10px;
}

/* ───────── Responsive ───────── */
@media (max-width: 768px) {
  .kpi-row { grid-template-columns: repeat(2, 1fr); }
  .profile-grid, .quote-grid { grid-template-columns: 1fr; }
  .rec-row { grid-template-columns: 1fr; }
  .rec-side { flex-direction: row; align-items: center; justify-content: flex-start; }
}
